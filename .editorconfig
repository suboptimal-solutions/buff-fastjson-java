root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.java]
indent_size = 4
max_line_length = 100

[*.proto]
indent_size = 4

[*.xml]
indent_size = 4

[*.md]
indent_size = 2
trim_trailing_whitespace = false
max_line_length = 120

[*.json]
indent_size = 2

[*.{yml,yaml}]
indent_size = 2

[{Makefile,makefile}]
indent_style = tab
